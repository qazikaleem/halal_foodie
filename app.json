{
  "expo": {
    "name": "Halal Food Near Me",
    "slug": "HalalFoodNearMe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "halalfoodnearme",
    "userInterfaceStyle": "automatic",
    //"newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.halalfoodie.HalalFoodNearMe",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAABMifab1QHriKktEeFEX6ME8rKR8F208"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "66e4873b-0390-49f3-bb48-23bad8c0a669"
      }
    }
  }
}